{
  "name": "sustainhub-backend",
  "version": "1.0.0",
  "description": "Backend API server for CSR and operational statistics tracking with ticket system",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
