# Database settings (replace with actual credentials)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/community_webapp?schema=public"

# Server configuration
PORT=5000
NODE_ENV=development

# JWT Secret keys for authentication
JWT_SECRET="your_jwt_access_secret_key_change_me_in_production"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_change_me_in_production"

# SharePoint Integration (Microsoft Graph API) settings (optional/mocked if empty)
SHAREPOINT_TENANT_ID="your_sharepoint_tenant_id"
SHAREPOINT_CLIENT_ID="your_sharepoint_client_id"
SHAREPOINT_CLIENT_SECRET="your_sharepoint_client_secret"
SHAREPOINT_LIST_ID="your_sharepoint_list_id"

# CORS configuration
FRONTEND_URL="http://localhost:5173"

# AI Providers compliance analysis (Optional fallbacks)
GROQ_API_KEY=""
GEMINI_API_KEY=""
NVIDIA_API_KEY=""
DEFAULT_AI_PROVIDER="groq"

